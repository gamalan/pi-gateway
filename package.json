{
  "name": "@gamalan/pi-gateway",
  "version": "1.4.2",
  "description": "Hermes-style messaging gateway for pi - multi-platform agent with sessions, security, and background tasks",
  "author": "0xKobold <original>; forked by gamalan",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "gateway",
    "messaging",
    "hermes",
    "multi-platform"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/",
    "config/",
    "README.md"
  ],
  "bin": {
    "pi-gateway": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npx tsx tests/index.ts",
    "demo": "npx tsx tests/demo-server.ts",
    "client": "npx tsx tests/client-demo.ts",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.19.37",
    "@types/ws": "^8.18.1",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.80.3",
    "@sinclair/typebox": ">=0.32.0"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gamalan/pi-gateway.git"
  }
}
